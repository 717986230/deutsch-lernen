/* ============================================================
   全局设计令牌 & 基础样式（多邻国清新绿）
   ============================================================ */
page {
  background-color: #f7f9fc;
  color: #3c3c3c;
  font-family: -apple-system, "Helvetica Neue", Arial, sans-serif;
  min-height: 100vh;
}

/* ---------- 颜色工具类 ---------- */
.gold      { color: #58cc02; }
.text-dim  { color: #777777; }
.text-faint{ color: #afafaf; }

/* ---------- 区块标题 ---------- */
.sec-title {
  display: flex;
  align-items: center;
  margin: 36rpx 0 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #e8eaed;
  position: relative;
}
/* 左侧绿色短线强调 */
.sec-title::before {
  content: '';
  position: absolute;
  left: 0;
  bottom: -1rpx;
  width: 56rpx;
  height: 4rpx;
  background: #58cc02;
  border-radius: 2rpx;
}
.sec-title-icon  { font-size: 40rpx; margin-right: 12rpx; }
.sec-title-text  {
  font-size: 30rpx;
  color: #58cc02;
  letter-spacing: 2rpx;
  font-weight: 700;
}
.sec-title-count {
  font-size: 22rpx;
  color: #777777;
  margin-left: auto;
  background: rgba(88,204,2,0.10);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ---------- 卡片 ---------- */
.card {
  background: #ffffff;
  border: 1rpx solid #e8eaed;
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.15s;
}
.card:active {
  transform: scale(0.985);
  background: #f3fbe9;
  border-color: rgba(88,204,2,0.4);
}
.card-active {
  background: #f3fbe9;
  border-color: rgba(88,204,2,0.5);
  box-shadow: 0 4rpx 16rpx rgba(88,204,2,0.12);
}

/* ---------- 规则框 ---------- */
.rule-box {
  background: #f3fbe9;
  border: 1rpx solid rgba(88,204,2,0.25);
  border-radius: 28rpx;
  padding: 44rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.rule-box-title {
  font-size: 28rpx;
  color: #58cc02;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
  font-weight: 700;
}

/* ---------- 提示卡片 ---------- */
.tip-card {
  background: #ffffff;
  border-left: 6rpx solid #58cc02;
  border-top: 1rpx solid #e8eaed;
  border-bottom: 1rpx solid #e8eaed;
  border-right: 1rpx solid #e8eaed;
  border-radius: 0 24rpx 24rpx 0;
  padding: 32rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.tip-title {
  font-size: 26rpx;
  color: #58cc02;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
  font-weight: 700;
}
.tip-body {
  font-size: 26rpx;
  color: #777777;
  line-height: 1.9;
}

/* ---------- 英雄区 ---------- */
.hero {
  text-align: center;
  padding: 88rpx 32rpx 72rpx;
  background:
    radial-gradient(ellipse 70% 50% at 50% 0%, rgba(88,204,2,0.14) 0%, transparent 70%),
    linear-gradient(180deg, rgba(88,204,2,0.08) 0%, transparent 100%);
  position: relative;
}
/* 顶部装饰线 */
.hero::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 120rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, #58cc02, transparent);
  border-radius: 2rpx;
}
.hero-label {
  font-size: 22rpx;
  letter-spacing: 12rpx;
  color: #58cc02;
  text-transform: uppercase;
  margin-bottom: 28rpx;
  font-weight: 700;
}
.hero-title {
  font-size: 80rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #2b2b2b;
  margin-bottom: 20rpx;
}
.hero-sub {
  font-size: 28rpx;
  color: #777777;
  line-height: 1.7;
}

/* ---------- 容器 ---------- */
.container {
  padding: 0 32rpx 100rpx;
}

/* ---------- 进度条 ---------- */
.progress-bar {
  height: 12rpx;
  background: #e8eaed;
  border-radius: 6rpx;
  margin: 16rpx 0;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #58cc02, #46a302);
  border-radius: 6rpx;
}

/* ---------- 按钮（多邻国 3D 按钮） ---------- */
.btn {
  display: inline-block;
  padding: 22rpx 56rpx;
  border-radius: 28rpx;
  border: none;
  border-bottom: 6rpx solid #46a302;
  background: #58cc02;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.btn:active {
  transform: translateY(4rpx);
  border-bottom: 2rpx solid #46a302;
  background: #4fb802;
}

/* ---------- 级别徽章 ---------- */
.level-badge {
  display: inline-block;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  margin-left: 8rpx;
  letter-spacing: 1rpx;
}
.lb-0  { background: rgba(88,204,2,0.15);  color: #58cc02;  border: 1rpx solid rgba(88,204,2,0.3); }
.lb-a1 { background: rgba(28,176,246,0.15); color: #1cb0f6;  border: 1rpx solid rgba(28,176,246,0.3); }
.lb-a2 { background: rgba(255,150,0,0.15);  color: #ff9600;  border: 1rpx solid rgba(255,150,0,0.3); }
.lb-b1 { background: rgba(255,122,77,0.15); color: #ff7a4d;  border: 1rpx solid rgba(255,122,77,0.3); }
.lb-b2 { background: rgba(206,130,255,0.15); color: #ce82ff; border: 1rpx solid rgba(206,130,255,0.3); }

/* ---------- 通用工具类（新增） ---------- */

/* 分隔线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #e8eaed, transparent);
  margin: 32rpx 0;
}

/* 可点元素通用按压态 */
.pressable:active {
  opacity: 0.78;
  transform: scale(0.975);
}

/* 玻璃卡片 */
.glass-card {
  background: #ffffff;
  border: 1rpx solid #e8eaed;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 绿色文字强调 */
.gold-glow { color: #58cc02; }

/* 内容块间距标准 */
.section-gap { margin-bottom: 40rpx; }
