.page { background: #f7f9fc; min-height: 100vh; }
.container { padding: 48rpx 40rpx 80rpx; text-align: center; }

.ico { font-size: 96rpx; margin: 24rpx 0 16rpx; }
.title { font-size: 40rpx; font-weight: 600; color: #2b2b2b; margin-bottom: 16rpx; }
.sub { font-size: 26rpx; color: #777777; line-height: 1.7; margin-bottom: 40rpx; }

.card {
  background: #ffffff;
  border: 1rpx solid #e8eaed;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: left;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 40rpx;
}
.card-row {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #3c3c3c;
  line-height: 1.7;
  margin-bottom: 16rpx;
}
.card-row:last-child { margin-bottom: 0; }
.dot {
  color: #58cc02;
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.hl { color: #58cc02; font-weight: 600; }

.btn {
  background: #58cc02;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx;
  border-radius: 48rpx;
  border-bottom: 6rpx solid #46a302;
  letter-spacing: 2rpx;
}
.btn:active { transform: translateY(4rpx); border-bottom-width: 2rpx; }
.btn-disabled { background: #bdbdbd; border-bottom-color: #9e9e9e; }

.tip { font-size: 24rpx; color: #777777; margin-top: 32rpx; line-height: 1.6; }
.tip2 { font-size: 22rpx; color: #afafaf; margin-top: 12rpx; line-height: 1.6; }
