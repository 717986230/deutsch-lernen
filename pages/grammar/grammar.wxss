.page { background: #f7f9fc; min-height: 100vh; }
.container { padding: 0 32rpx 100rpx; }

/* ---- 性别卡片 ---- */
.gender-grid { display: flex; gap: 18rpx; margin-top: 16rpx; }
.gender-card {
  flex: 1;
  text-align: center;
  padding: 28rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid;
  white-space: pre-line;
  font-size: 26rpx;
  line-height: 1.7;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06), inset 0 1rpx 0 rgba(255,255,255,0.6);
}

/* ---- 动词变位表格 ---- */
.verb-table { font-size: 26rpx; }
.verb-header {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(88,204,2,0.2);
  color: rgba(88,204,2,0.6);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  font-weight: 600;
}
.verb-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e8eaed;
  align-items: center;
}
.verb-row:active { background: rgba(88,204,2,0.04); }
.vc1 { width: 180rpx; flex-shrink: 0; }
.vc2 { flex: 1; color: #777777; }
.vc3 { width: 180rpx; flex-shrink: 0; }
.vc4 { width: 80rpx; }
.dim  { color: #777777; }
.gold { color: #58cc02; }
.irreg-row {
  font-size: 26rpx;
  color: #777777;
  line-height: 2.3;
}

/* ---- 格位变化表格 ---- */
.case-table { margin-bottom: 36rpx; font-size: 24rpx; }
.case-header {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(88,204,2,0.2);
  color: rgba(88,204,2,0.6);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  font-weight: 600;
}
.case-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e8eaed;
  white-space: pre-line;
}
.case-row:active { background: rgba(88,204,2,0.04); }
.cc1 { width: 180rpx; flex-shrink: 0; font-size: 22rpx; line-height: 1.5; color: #777777; }
.cc2 { flex: 1; }
.cc3, .cc4, .cc5 { width: 80rpx; flex-shrink: 0; }

/* ---- 模式行 ---- */
.pattern-row {
  font-size: 28rpx;
  color: #777777;
  line-height: 2.4;
}
