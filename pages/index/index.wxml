<scroll-view class="page" scroll-y>
  <view class="hero">
    <view class="hero-label">Deutsche Sprache · 德语学习</view>
    <view class="hero-title">德语学习手册</view>
    <view class="hero-sub">发音 · 数字 · 语法 · 3100+ 词句 · 5阶段进阶 · 互动测验</view>
  </view>

  <view class="container">
    <!-- 功能入口 -->
    <view class="feature-grid">
      <view class="feature-card" bindtap="goPage" data-url="/pages/pronunciation/pronunciation">
        <view class="feature-icon">🔤</view>
