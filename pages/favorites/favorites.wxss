.fav-page {
  min-height: 100vh;
  background: #f7f9fc;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.fav-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 120rpx;
}

.fav-loading-text {
  font-size: 28rpx;
  color: #777777;
}

.fav-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
  gap: 32rpx;
}

.fav-empty-icon {
  font-size: 80rpx;
  color: rgba(88,204,2,0.4);
}

.fav-empty-text {
  font-size: 28rpx;
  color: #777777;
  text-align: center;
  line-height: 1.8;
}

.fav-header {
  margin-bottom: 24rpx;
}

.fav-header-text {
  font-size: 24rpx;
  color: #777777;
}

.fav-item {
  margin-bottom: 8rpx;
}

.fav-remove {
  display: flex;
  justify-content: flex-end;
  padding: 8rpx 0 16rpx;
}

.fav-remove-text {
  font-size: 22rpx;
  color: rgba(255,75,75,0.7);
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(255,75,75,0.3);
  border-radius: 20rpx;
}
