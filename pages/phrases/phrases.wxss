.page { display: flex; flex-direction: column; height: 100vh; background: #f7f9fc; }
.header  { flex-shrink: 0; padding: 0 32rpx; }
.content { flex: 1; padding: 0 32rpx 40rpx; overflow: hidden; }

.loading, .empty {
  text-align: center;
  color: #777777;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* ---- 搜索框 ---- */
.search-wrap { position: relative; margin: 20rpx 0; }
.search-input {
  width: 100%;
  padding: 26rpx 80rpx 26rpx 40rpx;
  border-radius: 60rpx;
  border: 1rpx solid rgba(88,204,2,0.35);
  background: linear-gradient(135deg, rgba(88,204,2,0.07) 0%, rgba(88,204,2,0.02) 100%);
  color: #3c3c3c;
  font-size: 28rpx;
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(88,204,2,0.08);
}
.search-ph { color: #afafaf; }
.search-icon {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.35;
  font-size: 32rpx;
}

/* ---- 级别 tab ---- */
.level-tabs { white-space: nowrap; padding: 10rpx 0; }
.level-tab {
  display: inline-block;
  padding: 14rpx 32rpx;
  margin-right: 14rpx;
  border-radius: 44rpx;
  border: 1rpx solid rgba(88,204,2,0.15);
  color: #afafaf;
  font-size: 26rpx;
  transition: all 0.15s;
}
.level-tab:active { opacity: 0.75; transform: scale(0.96); }
.level-tab-active {
  border-color: #58cc02;
  background: linear-gradient(135deg, rgba(88,204,2,0.22) 0%, rgba(88,204,2,0.1) 100%);
  color: #46a302;
  font-weight: 600;
  box-shadow: 0 0 12rpx rgba(88,204,2,0.2);
}

/* ---- 级别信息栏 ---- */
.level-info {
  border-left: 4rpx solid #58cc02;
  background: linear-gradient(135deg, rgba(88,204,2,0.07) 0%, #ffffff 100%);
  border-top: 1rpx solid rgba(88,204,2,0.1);
  border-bottom: 1rpx solid rgba(88,204,2,0.06);
  border-right: 1rpx solid rgba(88,204,2,0.06);
  padding: 18rpx 28rpx;
  border-radius: 0 16rpx 16rpx 0;
  margin: 10rpx 0 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #777777;
}

/* ---- 分类 tab ---- */
.cat-tabs { white-space: nowrap; padding: 12rpx 0 10rpx; }
.cat-tab {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 36rpx;
  border: 1rpx solid rgba(88,204,2,0.12);
  color: #afafaf;
  font-size: 24rpx;
  transition: all 0.15s;
}
.cat-tab:active { opacity: 0.75; transform: scale(0.96); }
.cat-tab-active {
  border-color: #58cc02;
  background: linear-gradient(135deg, rgba(88,204,2,0.2) 0%, rgba(88,204,2,0.08) 100%);
  color: #58cc02;
  font-weight: 600;
}

/* ---- 级别徽章 ---- */
.level-badge { display: inline-block; padding: 2rpx 12rpx; border-radius: 20rpx; font-size: 18rpx; margin-left: 6rpx; }
.lb-0  { background: rgba(88,204,2,0.15);  color: #58cc02;  border: 1rpx solid rgba(88,204,2,0.22); }
.lb-a1 { background: rgba(28,176,246,0.15);  color: #1cb0f6;  border: 1rpx solid rgba(28,176,246,0.22); }
.lb-a2 { background: rgba(255,150,0,0.15);  color: #ff9600;  border: 1rpx solid rgba(255,150,0,0.28); }
.lb-b1 { background: rgba(255,122,77,0.15);  color: #ff7a4d;  border: 1rpx solid rgba(255,122,77,0.22); }
.lb-b2 { background: rgba(206,130,255,0.15);   color: #ce82ff;  border: 1rpx solid rgba(206,130,255,0.22);  }

/* ---- 结果文字 ---- */
.result-text {
  font-size: 24rpx;
  color: rgba(88,204,2,0.45);
  margin: 12rpx 0;
  letter-spacing: 1rpx;
}

/* ---- 词句列表 ---- */
.section { margin-bottom: 24rpx; }
.phrase-grid { display: grid; grid-template-columns: 1fr; gap: 14rpx; }

/* 全部级别下的引导提示 */
.cat-hint { font-size: 24rpx; color: #afafaf; padding: 16rpx 4rpx 8rpx; }
