/* tip-card 组件样式 */
.tip-card {
  background: linear-gradient(135deg, rgba(88,204,2,0.07) 0%, #ffffff 100%);
  border-left: 4rpx solid #58cc02;
  border-top: 1rpx solid rgba(88,204,2,0.12);
  border-bottom: 1rpx solid rgba(88,204,2,0.07);
  border-right: 1rpx solid rgba(88,204,2,0.07);
  border-radius: 0 24rpx 24rpx 0;
  padding: 32rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05), inset 0 1rpx 0 rgba(88,204,2,0.1);
}

.tip-title {
  display: block;
  font-size: 26rpx;
  color: #58cc02;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.tip-body {
  display: block;
  font-size: 26rpx;
  color: #777777;
  line-height: 1.9;
  white-space: pre-line;
}
